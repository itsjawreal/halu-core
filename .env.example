# halu-core configuration
# Copy this file to .env and adjust as needed.
# No paid API keys are required.

HALU_CORE_ENV=development
HALU_CORE_DATA_DIR=./data
HALU_CORE_DATABASE_URL=sqlite:///./data/halu_core.db
HALU_CORE_BASE_URL=http://127.0.0.1:8000

# Optional (Phase 8.7): a separate connection string Alembic uses
# instead of HALU_CORE_DATABASE_URL above. Useful when the runtime URL
# is a pooled connection (e.g. Neon's pooled endpoint) that DDL/migrations
# shouldn't run against directly -- point this at a direct, non-pooled
# connection instead. If unset, migrations fall back to
# HALU_CORE_DATABASE_URL, which is fine for a plain, unpooled database.
# HALU_CORE_MIGRATION_DATABASE_URL=

# Run lifecycle
HALU_CORE_RUN_TTL_SECONDS=1800
HALU_CORE_TOKEN_BYTES=32
HALU_CORE_VIEW_TOKEN_TTL_SECONDS=604800

# Rate limiting (per-run Agent API)
HALU_CORE_RATE_LIMIT_READ_PER_MINUTE=120
HALU_CORE_RATE_LIMIT_WRITE_PER_MINUTE=60
HALU_CORE_RATE_LIMIT_WINDOW_SECONDS=60

# Abuse protection (Phase 8)
HALU_CORE_MAX_RUN_TTL_SECONDS=86400
HALU_CORE_MAX_ACTIONS_PER_RUN=500
HALU_CORE_MAX_FINAL_REPORT_LENGTH=20000
HALU_CORE_MAX_CLAIMS_PER_REPORT=100
HALU_CORE_MAX_JSON_DEPTH=20

# Data retention, in days (Phase 8) -- 0 disables that bucket's cleanup
HALU_CORE_RETENTION_INCOMPLETE_RUN_DAYS=7
HALU_CORE_RETENTION_COMPLETED_RUN_DAYS=90
HALU_CORE_RETENTION_PUBLIC_SHARE_DAYS=365
HALU_CORE_RETENTION_EVENT_DAYS=90
HALU_CORE_RETENTION_EXPIRED_TOKEN_DAYS=30
